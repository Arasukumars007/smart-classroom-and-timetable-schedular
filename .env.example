# Database
POSTGRES_USER=scadmin
POSTGRES_PASSWORD=scpassword
POSTGRES_DB=smart_classroom

# Security
SECRET_KEY=supersecretkey_change_in_production_32chars_minimum
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS - Comma-separated origins
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# For local dev without Docker (PostgreSQL or SQLite)
# DATABASE_URL=postgresql+asyncpg://scadmin:scpassword@localhost:5432/smart_classroom
DATABASE_URL=sqlite+aiosqlite:///./smart_classroom.db

