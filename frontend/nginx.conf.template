server {
    # Railway (and other PaaS) set a dynamic $PORT — nginx:alpine auto-substitutes
    # this via the /etc/nginx/templates/ mechanism using envsubst.
    listen ${PORT};
    server_name localhost;

    location / {
        root /usr/share/nginx/html;
        index index.html index.htm;
        try_files $uri $uri/ /index.html;
    }

    error_page 500 502 503 504 /50x.html;
    location = /50x.html {
        root /usr/share/nginx/html;
    }
}
