# ─── Frontend Environment Variables ───────────────────────────────────────────
# Copy this file to .env.local for local development.
# For production (Render/PaaS), set these as Build Environment Variables
# in the dashboard — do NOT commit .env.local to git.

# The full URL of the deployed FastAPI backend.
# Leave empty for local development (Vite's proxy handles /api routing).
# Example (Render): https://smart-classroom-api.onrender.com
VITE_API_BASE_URL=
